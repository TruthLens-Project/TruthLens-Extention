{
  "manifest_version": 3,
  "name": "TruthLens - Validity Checker",
  "version": "1.0",
  "description": "Analyze text and articles for truthfulness using AI.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "scripting",
    "tabCapture"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "utils/Readability.js",
        "content.js"
      ]
    },
    {
      "matches": [
        "*://twitter.com/*",
        "*://x.com/*",
        "*://web.whatsapp.com/*"
      ],
      "js": [
        "social_overlay.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Check Validity"
  }
}